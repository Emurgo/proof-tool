{
  "name": "@proof-zk-recovery/ownership-proof-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "dev:proof-assets": "node scripts/proof-assets-dev-server.mjs",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "deploy:reclaim:preprod": "node e2e/preprod/deploy-reclaim-preprod.mjs",
    "e2e:preprod:stage2g:v2:material": "node e2e/preprod/stage2g-v2-material.mjs",
    "e2e:preprod:stage2g:v2:evaluate": "node e2e/preprod/stage2g-v2-evaluate.mjs",
    "e2e:preprod:stage2g:v2:compare": "node e2e/preprod/stage2g-v2-compare.mjs",
    "e2e:preprod:lace:setup": "node e2e/preprod/lace-profile-setup.mjs",
    "test:e2e:preprod": "node e2e/preprod/run.mjs",
    "test:e2e:preprod:lace-smoke": "RECLAIM_E2E_WALLET_MODE=lace node e2e/preprod/run.mjs",
    "test:e2e:preprod:web-app-claim-flow-wasm-lace:local-pr": "node e2e/preprod/local-web-app-claim-flow-wasm-lace.mjs",
    "push:pr:with-local-claim-flow": "node e2e/preprod/push-pr-with-local-claim-flow.mjs",
    "typecheck": "tsc --noEmit",
    "verify:proof-release": "node scripts/verify-proof-release.mjs --web-root public --deployment public/proof-assets/reclaim-deployment.json",
    "verify:proof-release:live": "node scripts/verify-proof-release.mjs --base-url \"$PROOF_RELEASE_BASE_URL\"",
    "verify:reclaim-manifest": "node scripts/verify-reclaim-manifest.mjs",
    "visual:claim": "node scripts/claim-ui-visual-check.mjs",
    "visual:claim:strict": "CLAIM_VISUAL_STRICT=1 node scripts/claim-ui-visual-check.mjs",
    "visual:lock-funds": "NEXT_PUBLIC_LOCK_FUNDS_UI_FIXTURE=1 node scripts/lock-funds-ui-visual-check.mjs",
    "visual:lock-funds:strict": "NEXT_PUBLIC_LOCK_FUNDS_UI_FIXTURE=1 LOCK_FUNDS_VISUAL_STRICT=1 node scripts/lock-funds-ui-visual-check.mjs"
  },
  "dependencies": {
    "@lucid-evolution/core-types": "0.2.1",
    "@lucid-evolution/lucid": "0.5.5",
    "@lucid-evolution/provider": "0.1.96",
    "@noble/hashes": "1.8.0",
    "@proof-zk-recovery/proof-tool-client": "file:../../packages/client-ts",
    "bech32": "2.0.0",
    "lucide-react": "^0.468.0",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "jsdom": "^25.0.0",
    "pixelmatch": "^7.2.0",
    "playwright": "1.61.1",
    "pngjs": "^7.0.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  }
}
