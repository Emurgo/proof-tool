+// VectorSource supplies the proving-key point-vectors one section at a time so
+// the streaming prover (ProveStream) never holds the whole pk resident. Section
+// names match the streampk index: "A","B","Z","K" (G1.A/B/Z/K), "G2B" (G2.B),
+// and the Pedersen commitment vectors "Basis"/"BasisExpSigma" ("Basis_i"/
+// "BasisExpSigma_i" for commitment key i>0). Each call loads the named vector
+// into buf (grown/reused as needed) and returns it; ProveStream drops the
+// reference after the MSM so at most one large G1 (and one G2) section is in
+// flight at a time. *streampk.KeySource satisfies this interface directly.
+//
+// MEMPROBE LEVER (not upstream): this is the streaming hand-off for the WASM/TEE
+// recovery prover. It changes only WHERE the MSM points come from, never the MSM
+// math, so the RNG-independent artifacts (the BSB22 commitment and its e_cmt
+// challenge) stay byte-identical to a stock Prove of the same witness.
+type VectorSource interface {
+	G1(name string, buf []curve.G1Affine) ([]curve.G1Affine, error)
+	G2(name string, buf []curve.G2Affine) ([]curve.G2Affine, error)
+	// G1Range/G2Range fetch only points [lo,hi) of the named section. They let
+	// the MSM engine pull each shard's points on demand so the whole vector is
+	// never resident in the main instance (the range-fetch memory lever); the
+	// engine fetches and frees one shard at a time.
+	G1Range(name string, lo, hi int, buf []curve.G1Affine) ([]curve.G1Affine, error)
+	G2Range(name string, lo, hi int, buf []curve.G2Affine) ([]curve.G2Affine, error)
+	PKSectionPlan() *msmengine.PKSectionPlan
+}
+
+// ProveStream is the streaming fork of Prove. The Groth16 math is IDENTICAL; the
+// only change is provenance: every large proving-key point-vector is read from
+// src one vector at a time (loaded immediately before its MultiExp, dropped
+// after) instead of living resident on pk. pk carries ONLY the small in-memory
+// parts — Domain (for Cardinality), G1.Alpha/Beta/Delta, G2.Beta/Delta, the
+// InfinityA/B masks, and CommitmentKeys metadata whose Basis/BasisExpSigma are
+// nil on entry (ProveStream loads them from src).
+//
+// Phase-0 levers preserved: every MultiExp/Fold uses MultiExpConfig{NbTasks:1}
+// and the MSMs run strictly serially (on single-threaded wasm the concurrency
+// buys no speed but multiplies peak memory). computeH builds a fresh
+// WithoutPrecompute domain to drop the ~0.5 GiB twiddle tables.
+//
+// Because only the point provenance changes, the proof's BSB22 Pedersen
+// commitment and its expand_message_xmd challenge e_cmt are byte-identical to a
+// stock Prove of the same witness; only the random r,s (and thus Ar/Bs/Krs)
+// differ.
+func ProveStream(r1cs *cs.R1CS, pk *ProvingKey, src VectorSource, fullWitness witness.Witness, opts ...backend.ProverOption) (*Proof, error) {
+	opt, err := backend.NewProverConfig(opts...)
+	if err != nil {
+		return nil, fmt.Errorf("new prover config: %w", err)
+	}
+	if opt.HashToFieldFn == nil {
+		opt.HashToFieldFn = hash_to_field.New([]byte(constraint.CommitmentDst))
+	}
+
+	log := logger.Logger().With().Str("curve", r1cs.CurveID().String()).Str("acceleration", "streampk").Int("nbConstraints", r1cs.GetNbConstraints()).Str("backend", "groth16").Logger()
+
+	commitmentInfo := r1cs.CommitmentInfo.(constraint.Groth16Commitments)
+
+	proof := &Proof{Commitments: make([]curve.G1Affine, len(commitmentInfo))}
+
+	solverOpts := opt.SolverOpts[:len(opt.SolverOpts):len(opt.SolverOpts)]
+
+	privateCommittedValues := make([][]fr.Element, len(commitmentInfo))
+
+	// override hints — identical to Prove: the Commit here (over Basis) is what
+	// fixes proof.Commitments[i] and hence e_cmt.
+	bsb22ID := solver.GetHintID(fcs.Bsb22CommitmentComputePlaceholder)
+	solverOpts = append(solverOpts, solver.OverrideHint(bsb22ID, func(_ *big.Int, in []*big.Int, out []*big.Int) error {
+		i := int(in[0].Int64())
+		in = in[1:]
+		privateCommittedValues[i] = make([]fr.Element, len(commitmentInfo[i].PrivateCommitted))
+		hashed := in[:len(commitmentInfo[i].PublicAndCommitmentCommitted)]
+		committed := in[+len(hashed):]
+		for j, inJ := range committed {
+			privateCommittedValues[i][j].SetBigInt(inJ)
+		}
+
+		var cmtJac curve.G1Jac
+		basisName := commitmentSectionName("Basis", i)
+		endMSM := msmengine.TraceStage("commitment Basis MSM", map[string]any{
+			"commitment_index": i,
+			"section":          basisName,
+			"scalars":          len(privateCommittedValues[i]),
+		})
+		if err := msmG1SectionOrRange(&cmtJac, src, basisName, len(privateCommittedValues[i]), privateCommittedValues[i]); err != nil {
+			endMSM(map[string]any{"error": err.Error()})
+			return err
+		}
+		endMSM(nil)
+		proof.Commitments[i].FromJacobian(&cmtJac)
+
+		opt.HashToFieldFn.Write(constraint.SerializeCommitment(proof.Commitments[i].Marshal(), hashed, (fr.Bits-1)/8+1))
+		hashBts := opt.HashToFieldFn.Sum(nil)
+		opt.HashToFieldFn.Reset()
+		nbBuf := fr.Bytes
+		if opt.HashToFieldFn.Size() < fr.Bytes {
+			nbBuf = opt.HashToFieldFn.Size()
+		}
+		var res fr.Element
+		res.SetBytes(hashBts[:nbBuf])
+		res.BigInt(out[0])
+		return nil
+	}))
+
+	restoreSolverGC, solverGCFields := suspendWasmGCForSolver()
+	endSolver := msmengine.TraceStage("solver", map[string]any{
+		"constraints":  r1cs.GetNbConstraints(),
+		"gc_suspended": solverGCFields["gc_suspended"],
+	})
+	_solution, err := r1cs.Solve(fullWitness, solverOpts...)
+	restoreSolverGC()
+	if err != nil {
+		endSolver(map[string]any{"error": err.Error()})
+		return nil, err
+	}
+	endSolver(nil)
+
+	solution := _solution.(*cs.R1CSSolution)
+	wireValues := []fr.Element(solution.W)
+
+	start := time.Now()
+
+	// O2: computeH needs only solution.A/B/C and is consumed only by Z below.
+	// Launch it while the worker-bound PoK/G2B/A/B stages run; the main
+	// goroutine joins before Z, preserving all Groth16 dependencies.
+	domain := fft.NewDomain(pk.Domain.Cardinality, fft.WithoutPrecompute())
+	hCh := make(chan []fr.Element, 1)
+	go func(a, b, c []fr.Element) {
+		endComputeH := msmengine.TraceStage("computeH / FFT", map[string]any{
+			"domain_cardinality": pk.Domain.Cardinality,
+			"overlapped_with":    "commitment BasisExpSigma MSM,G2B,A,B",
+		})
+		h := computeH(a, b, c, domain)
+		endComputeH(map[string]any{"h_scalars": len(h)})
+		runtime.GC()
+		hCh <- h
+	}(solution.A, solution.B, solution.C)
+	solution.A = nil
+	solution.B = nil
+	solution.C = nil
+
+	// PoK of each commitment (over BasisExpSigma), then fold via the G16-BSB22
+	// challenge — identical to Prove.
+	poks := make([]curve.G1Affine, len(pk.CommitmentKeys))
+	for i := range pk.CommitmentKeys {
+		var pokJac curve.G1Jac
+		sigmaName := commitmentSectionName("BasisExpSigma", i)
+		endMSM := msmengine.TraceStage("commitment BasisExpSigma MSM", map[string]any{
+			"commitment_index": i,
+			"section":          sigmaName,
+			"scalars":          len(privateCommittedValues[i]),
+		})
+		if err := msmG1SectionOrRange(&pokJac, src, sigmaName, len(privateCommittedValues[i]), privateCommittedValues[i]); err != nil {
+			endMSM(map[string]any{"error": err.Error()})
+			return nil, err
+		}
+		endMSM(nil)
+		poks[i].FromJacobian(&pokJac)
+	}
+	commitmentsSerialized := make([]byte, fr.Bytes*len(commitmentInfo))
+	for i := range commitmentInfo {
+		copy(commitmentsSerialized[fr.Bytes*i:], wireValues[commitmentInfo[i].CommitmentIndex].Marshal())
+	}
+	challenge, err := fr.Hash(commitmentsSerialized, []byte("G16-BSB22"), 1)
+	if err != nil {
+		return nil, err
+	}
+	if _, err = proof.CommitmentPok.Fold(poks, challenge[0], ecc.MultiExpConfig{NbTasks: 1}); err != nil {
+		return nil, err
+	}
+
+	// privateCommittedValues has served its purpose (Commit inside Solve +
+	// ProveKnowledge). Nil it now so the forced GC below can reclaim it.
+	privateCommittedValues = nil
+
+	// Build B scalars first so G2B can run while the main goroutine prepares
+	// the remaining scalar subsets. Worker-bound MSMs remain serial: A starts
+	// only after G2B returns.
+	wireValuesB := make([]fr.Element, len(wireValues)-int(pk.NbInfinityB))
+	for i, j := 0, 0; j < len(wireValuesB); i++ {
+		if pk.InfinityB[i] {
+			continue
+		}
+		wireValuesB[j] = wireValues[i]
+		j++
+	}
+
+	// sample random r and s (RNG-dependent: this is the ONLY source of difference
+	// from a stock prove; e_cmt above is already fixed).
+	var r, s big.Int
+	var _r, _s, _kr fr.Element
+	if _, err := _r.SetRandom(); err != nil {
+		return nil, err
+	}
+	if _, err := _s.SetRandom(); err != nil {
+		return nil, err
+	}
+	_kr.Mul(&_r, &_s).Neg(&_kr)
+	_r.BigInt(&r)
+	_s.BigInt(&s)
+
+	// computes r[δ], s[δ], kr[δ] from the in-memory pk.G1.Delta.
+	deltas := curve.BatchScalarMultiplicationG1(&pk.G1.Delta, []fr.Element{_r, _s, _kr})
+
+	g2bDone := make(chan error, 1)
+	go func() {
+		var Bs, deltaS curve.G2Jac
+		endMSM := msmengine.TraceStage("G2B", map[string]any{
+			"scalars":         len(wireValuesB),
+			"overlapped_with": "scalar prep",
+		})
+		if err := msmG2SectionOrRange(&Bs, src, "G2B", len(wireValuesB), wireValuesB); err != nil {
+			endMSM(map[string]any{"error": err.Error()})
+			g2bDone <- err
+			return
+		}
+		endMSM(nil)
+		deltaS.FromAffine(&pk.G2.Delta)
+		deltaS.ScalarMultiplication(&deltaS, &s)
+		Bs.AddAssign(&deltaS)
+		Bs.AddMixed(&pk.G2.Beta)
+		proof.Bs.FromJacobian(&Bs)
+		g2bDone <- nil
+	}()
+
+	// Filter wireValues for A while G2B workers are busy.
+	wireValuesA := make([]fr.Element, len(wireValues)-int(pk.NbInfinityA))
+	for i, j := 0, 0; j < len(wireValuesA); i++ {
+		if pk.InfinityA[i] {
+			continue
+		}
+		wireValuesA[j] = wireValues[i]
+		j++
+	}
+
+	// Precompute _wireValues (the G1.K filtered subset of wireValues) while
+	// G2B workers are busy, then drop the full wireValues slice.
+	toRemoveK := commitmentInfo.GetPrivateCommitted()
+	toRemoveK = append(toRemoveK, commitmentInfo.CommitmentIndexes())
+	_wireValues := filterHeap(wireValues[r1cs.GetNbPublicVariables():], r1cs.GetNbPublicVariables(), internal.ConcatAll(toRemoveK...))
+	wireValues = nil
+
+	// RANGE-FETCH LEVER (Task "Browser latency"): the five big MSMs below no
+	// longer load a whole point-vector into this (main) instance. Each calls the
+	// engine's MSM*Ranged variant with a src.G1Range/G2Range closure, so the
+	// engine fetches each shard's points on demand and frees them after the
+	// shard — the ≤588 MiB G2.B vector (and the A/B/Z/K vectors) never sit
+	// resident here. The Groth16 math is unchanged (an MSM is a group sum), so
+	// the proof and its e_cmt stay bit-identical to a whole-vector prove.
+
+	if err := <-g2bDone; err != nil {
+		return nil, err
+	}
+
+	// Ar (G1.A) -> ar (kept as Jacobian; Krs scalar-multiplies it by s).
+	var ar curve.G1Jac
+	endA := msmengine.TraceStage("A", map[string]any{"scalars": len(wireValuesA)})
+	if err := msmG1SectionOrRange(&ar, src, "A", len(wireValuesA), wireValuesA); err != nil {
+		endA(map[string]any{"error": err.Error()})
+		return nil, err
+	}
+	endA(nil)
+	wireValuesA = nil
+	ar.AddMixed(&pk.G1.Alpha)
+	ar.AddMixed(&deltas[0])
+	proof.Ar.FromJacobian(&ar)
+
+	// Bs1 (G1.B) -> bs1 (kept as Jacobian; Krs scalar-multiplies it by r).
+	var bs1 curve.G1Jac
+	endB := msmengine.TraceStage("B", map[string]any{"scalars": len(wireValuesB)})
+	if err := msmG1SectionOrRange(&bs1, src, "B", len(wireValuesB), wireValuesB); err != nil {
+		endB(map[string]any{"error": err.Error()})
+		return nil, err
+	}
+	endB(nil)
+	wireValuesB = nil
+	bs1.AddMixed(&pk.G1.Beta)
+	bs1.AddMixed(&deltas[1])
+
+	h := <-hCh
+	runtime.GC()
+
+	// Krs = Z·h + K·w + kr[δ] + s·ar + r·bs1. Group addition is commutative so the
+	// result equals the stock Krs regardless of section order.
+	{
+		var krs, krs2, p1 curve.G1Jac
+		sizeH := int(pk.Domain.Cardinality - 1) // deg(H)=(n-1)+(n-1)-n=n-2
+
+		endZ := msmengine.TraceStage("Z", map[string]any{"scalars": sizeH})
+		if err := msmG1SectionOrRange(&krs2, src, "Z", sizeH, h[:sizeH]); err != nil {
+			endZ(map[string]any{"error": err.Error()})
+			return nil, err
+		}
+		endZ(nil)
+
+		// _wireValues was precomputed before the GC above to allow early nil of
+		// wireValues (it is the G1.K filtered scalar subset).
+		endK := msmengine.TraceStage("K", map[string]any{"scalars": len(_wireValues)})
+		if err := msmG1SectionOrRange(&krs, src, "K", len(_wireValues), _wireValues); err != nil {
+			endK(map[string]any{"error": err.Error()})
+			return nil, err
+		}
+		endK(nil)
+		krs.AddMixed(&deltas[2])
+		krs.AddAssign(&krs2)
+
+		p1.ScalarMultiplication(&ar, &s)
+		krs.AddAssign(&p1)
+		p1.ScalarMultiplication(&bs1, &r)
+		krs.AddAssign(&p1)
+
+		proof.Krs.FromJacobian(&krs)
+	}
+
+	log.Debug().Dur("took", time.Since(start)).Msg("prover done (streampk)")
+
+	return proof, nil
+}
+
+func msmG1SectionOrRange(dst *curve.G1Jac, src VectorSource, section string, n int, scalars []fr.Element) error {
+	if plan := src.PKSectionPlan(); plan != nil {
+		if engine, ok := msmengine.Current().(msmengine.PKSectionEngine); ok {
+			return engine.MSMG1Section(dst, plan, section, n, scalars, nil)
+		}
+	}
+	return msmengine.Current().MSMG1Ranged(dst, n, func(lo, hi int) ([]curve.G1Affine, error) {
+		return src.G1Range(section, lo, hi, nil)
+	}, scalars, nil)
+}
+
+func msmG2SectionOrRange(dst *curve.G2Jac, src VectorSource, section string, n int, scalars []fr.Element) error {
+	if plan := src.PKSectionPlan(); plan != nil {
+		if engine, ok := msmengine.Current().(msmengine.PKSectionEngine); ok {
+			return engine.MSMG2Section(dst, plan, section, n, scalars, nil)
+		}
+	}
+	return msmengine.Current().MSMG2Ranged(dst, n, func(lo, hi int) ([]curve.G2Affine, error) {
+		return src.G2Range(section, lo, hi, nil)
+	}, scalars, nil)
+}
+
+func commitmentSectionName(base string, i int) string {
+	if i == 0 {
+		return base
+	}
+	return fmt.Sprintf("%s_%d", base, i)
+}
+
+func suspendWasmGCForSolver() (func(), map[string]any) {
+	if runtime.GOOS != "js" || runtime.GOARCH != "wasm" {
+		return func() {}, map[string]any{"gc_suspended": false}
+	}
+	prevGCPercent := debug.SetGCPercent(-1)
+	prevMemLimit := debug.SetMemoryLimit(math.MaxInt64)
+	return func() {
+		debug.SetMemoryLimit(prevMemLimit)
+		debug.SetGCPercent(prevGCPercent)
+		runtime.GC()
+	}, map[string]any{"gc_suspended": true}
+}
+
 // if len(toRemove) == 0, returns slice
 // else, returns a new slice without the indexes in toRemove. The first value in the slice is taken as indexes as sliceFirstIndex
 // this assumes len(slice) > len(toRemove)
