+package groth16
+
+// prove_w8_test.go pins the opt-W8 contract: computeH routed through an
+// HTransformEngine must produce a vector identical to the serial main-thread
+// path, and the engine must be consulted exactly once per transform phase.
+// The stub below transforms with the same gnark FFT calls the real FFT
+// workers run (internal/msmengine hTransformVector), so this is the
+// schedule-level differential; the byte-level worker kernel is pinned by
+// TestHTransformMatchesSerialFFT in internal/msmengine.
+
+import (
+	"testing"
+
+	"github.com/consensys/gnark-crypto/ecc/bls12-381/fr"
+	"github.com/consensys/gnark-crypto/ecc/bls12-381/fr/fft"
+
+	"proof-tool/experiments/wasm-prover/msmengine"
+)
+
+type hTransformStub struct {
+	msmengine.MSMEngine
+	calls int
+}
+
+func (s *hTransformStub) HTransformEnabled() bool { return true }
+
+func (s *hTransformStub) TransformHVectors(vecs [][]fr.Element, inverse, coset bool, cardinality uint64) error {
+	s.calls++
+	domain := fft.NewDomain(cardinality, fft.WithoutPrecompute())
+	opts := []fft.Option{fft.WithNbTasks(1)}
+	if coset {
+		table := make([]fr.Element, cardinality)
+		if inverse {
+			fft.BuildExpTable(domain.FrMultiplicativeGenInv, table)
+		} else {
+			fft.BuildExpTable(domain.FrMultiplicativeGen, table)
+		}
+		opts = append(opts, fft.OnCoset(), fft.WithCosetTable(table))
+	}
+	for _, vec := range vecs {
+		if inverse {
+			domain.FFTInverse(vec, fft.DIF, opts...)
+		} else {
+			domain.FFT(vec, fft.DIT, opts...)
+		}
+	}
+	return nil
+}
+
+func TestComputeHW8EngineMatchesSerial(t *testing.T) {
+	const size = 13
+	aSerial, bSerial, cSerial := fixedComputeHWitness(size)
+	domainSerial := fft.NewDomain(16, fft.WithoutPrecompute())
+	want := computeHWithRuntime(aSerial, bSerial, cSerial, domainSerial, nil, true)
+
+	stub := &hTransformStub{}
+	previous := msmengine.Current()
+	msmengine.SetCurrent(stub)
+	defer msmengine.SetCurrent(previous)
+
+	aW8, bW8, cW8 := fixedComputeHWitness(size)
+	domainW8 := fft.NewDomain(16, fft.WithoutPrecompute())
+	yields := 0
+	got := computeHWithRuntime(aW8, bW8, cW8, domainW8, func() { yields++ }, true)
+
+	if stub.calls != 3 {
+		t.Fatalf("HTransformEngine consulted %d times, want 3 (iFFT, coset FFT, final coset iFFT)", stub.calls)
+	}
+	// The engine path yields once per offloaded input phase plus once after
+	// the pointwise product; the blocking channel receives inside the real
+	// engine pump the event loop on wasm, so per-vector yields are not needed.
+	if yields != 3 {
+		t.Fatalf("engine path yielded %d times, want 3", yields)
+	}
+	assertElementVectorsEqual(t, want, got)
+}
