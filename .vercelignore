output/
# Root-anchored: bare patterns follow gitignore semantics and match at any
# depth — an unanchored dist/ strips the tracked packages/client-ts/dist/
# (the @proof-zk-recovery/proof-tool-client entry points) from the upload
# and breaks the Vercel build.
/.codex/
/.claude/
/.agents/
/.git/
/vendor/
/.playwright-cli/
/.wrangler/
/audit/
/dist/
/experiments/
/contracts/
/cmd/
/internal/
/scripts/
/docs/
/apps/proof-helper-desktop/
.proof-tool/
.env.local
.env.*.local
deployments/reclaim/preprod/*.local.json
*.pk
*.vk
proof-tool.zip
apps/ownership-proof-web/.next/
apps/ownership-proof-web/node_modules/
apps/ownership-proof-web/tsconfig.tsbuildinfo
!apps/ownership-proof-web/public/proof-assets/ownership.vk
apps/proof-helper-desktop/dist/
apps/proof-helper-desktop/node_modules/
apps/proof-helper-desktop/src-tauri/target/
apps/proof-helper-desktop/src-tauri/binaries/proof-tool-*
packages/client-ts/node_modules/
packages/client-ts/.vite/
